# =============================================================================
# Sbobinator — variabili d'ambiente (solo quelle lette dal codice)
# =============================================================================
#
# Copia:  copy .env.example .env
#
# ATTENZIONE: Sbobinator NON carica automaticamente .env.
#             Esporta le variabili nel terminale, Docker Compose, direnv, ecc.
#
# API key — alternativa: sidebar UI → salva in data/.secrets/summary_keys.json
#
# Override modello riassunto: solo in summary_keys.json (es. "deepseek_model")
# Non esiste una variabile d'ambiente per quello.
#
# Porta UI: solo da CLI →  sbobina ui --port 8501
#
# =============================================================================


# Cartella radice input/output (default: ./data)
# SBOBINATOR_DATA=

# Cartella modelli ASR e LLM locale (default: ./models)
# NEMO_CACHE_DIR=

# Host interfaccia web (default: 127.0.0.1; Docker: 0.0.0.0)
# SBOBINATOR_UI_HOST=127.0.0.1

# API key provider riassunto cloud
# SBOBINATOR_OPENAI_API_KEY=
# SBOBINATOR_GEMINI_API_KEY=
# SBOBINATOR_ANTHROPIC_API_KEY=
# SBOBINATOR_DEEPSEEK_API_KEY=
# SBOBINATOR_KIMI_API_KEY=
